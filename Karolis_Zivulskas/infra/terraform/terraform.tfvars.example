# Copy to terraform.tfvars and fill in your values.
# terraform.tfvars is gitignored — never commit it.

ec2_key_pair        = "your-key-pair-name"          # must exist in eu-west-1
s3_evidence_bucket  = "repops-evidence-yourname"    # must be globally unique
allowed_ssh_cidr    = "0.0.0.0/0"                   # restrict to your IP: "1.2.3.4/32"

# Optional overrides (defaults are fine for staging)
# aws_region        = "eu-west-1"
# environment       = "staging"
# ec2_instance_type = "t3.medium"
