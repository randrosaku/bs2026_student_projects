          "rawSql": "SELECT\n  DATE_TRUNC('day', p.created_at)::date AS day,\n  p.post_type::text AS type,\n  COUNT(*) AS count\nFROM posts p\nJOIN targets t ON t.id = p.target_id\nWHERE ('$target' = '.*' OR t.facebook_id = '$target')\n  AND p.created_at >= $__timeFrom() AND p.created_at <= $__timeTo()\nGROUP BY 1, 2\nORDER BY 1",
