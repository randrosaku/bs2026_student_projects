        {
          "datasource": {
            "type": "postgres",
            "uid": "repops-postgres"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  p.posted_at,\n  t.name AS target,\n  COALESCE(pr.name, SUBSTRING(pr.facebook_id, 1, 25)) AS author,\n  p.post_type AS type,\n  LEFT(p.content, 350) AS content,\n  COALESCE(ar.overall_label::text, 'pending') AS label,\n  ROUND(COALESCE(ar.overall_score, 0)::numeric, 2) AS score,\n  ARRAY_TO_STRING(COALESCE(ar.matched_keywords, '{}'), ', ') AS keywords,\n  p.url\nFROM posts p\nLEFT JOIN analysis_results ar ON ar.post_id = p.id\nLEFT JOIN profiles pr ON pr.id = p.author_id\nJOIN targets t ON t.id = p.target_id\nWHERE ('$target' = '.*' OR t.facebook_id = '$target')\n  AND ('$post_type' = 'ALL' OR p.post_type::text = '$post_type')\n  AND p.created_at >= $__timeFrom()\n  AND p.created_at <= $__timeTo()\nORDER BY p.posted_at DESC\nLIMIT 300",
          "refId": "A"
        }
      ],
