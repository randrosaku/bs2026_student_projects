          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  p.posted_at,\n  t.name AS target,\n  COALESCE(pr.name, SUBSTRING(pr.facebook_id, 1, 25)) AS author,\n  p.post_type::text AS type,\n  LEFT(p.content, 350) AS content,\n  ARRAY_TO_STRING(ar.matched_keywords, ', ') AS keywords,\n  ar.keyword_severity::text AS severity,\n  ROUND(ar.overall_score::numeric, 2) AS score,\n  ar.overall_label::text AS label,\n  p.url\nFROM posts p\nJOIN analysis_results ar ON ar.post_id = p.id\nLEFT JOIN profiles pr ON pr.id = p.author_id\nJOIN targets t ON t.id = p.target_id\nWHERE ar.overall_label != 'CLEAN'\n  AND ('$target' = '.*' OR t.facebook_id = '$target')\n  AND p.created_at >= $__timeFrom() AND p.created_at <= $__timeTo()\nORDER BY p.posted_at DESC\nLIMIT 500",
