{
  "title": "RepOps - Platform Overview",
  "uid": "repops-overview",
  "tags": [
    "repops"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "30s",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Posts Collected (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 0,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_posts_collected_total[24h])",
          "legendFormat": "Posts",
          "instant": true
        }
      ]
    },
    {
      "id": 2,
      "title": "Posts Analyzed (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 4,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          },
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_posts_analyzed_total[24h])",
          "legendFormat": "Analyzed",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Keyword Matches (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 8,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 10
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_keyword_matches_total[24h])",
          "legendFormat": "Matches",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Posts Flagged (24h)",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_posts_flagged_total[24h])",
          "legendFormat": "Flagged",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Analysis p95 Latency",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 16,
        "y": 0
      },
      "options": {
        "colorMode": "value",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "noValue": "0"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "histogram_quantile(0.95, rate(repops_analysis_duration_seconds_bucket[10m])) * 1000",
          "legendFormat": "p95",
          "instant": true
        }
      ]
    },
    {
      "id": 6,
      "title": "Queue Depth",
      "type": "stat",
      "gridPos": {
        "h": 4,
        "w": 4,
        "x": 20,
        "y": 0
      },
      "options": {
        "colorMode": "background",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "noValue": "0",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(repops_queue_depth)",
          "legendFormat": "Total queued",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "title": "Collection & Analysis Throughput",
      "description": "Posts collected, analyzed, and flagged per 5-minute window.",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 14,
        "x": 0,
        "y": 4
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_posts_collected_total[5m])",
          "legendFormat": "collected"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_posts_analyzed_total[5m])",
          "legendFormat": "analyzed"
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_posts_flagged_total[5m])",
          "legendFormat": "flagged"
        }
      ]
    },
    {
      "id": 11,
      "title": "Celery Queue Depth by Queue",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 10,
        "x": 14,
        "y": 4
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "repops_queue_depth",
          "legendFormat": "{{queue_name}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Keyword Hits by Pattern",
      "description": "Which keywords are being matched (rate per 5m).",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_keyword_hits_total[5m])",
          "legendFormat": "{{pattern}} ({{severity}})"
        }
      ]
    },
    {
      "id": 13,
      "title": "Analysis Score Distribution (last 10m)",
      "description": "Histogram of hate-speech scores - shows how close content gets to flagging thresholds.",
      "type": "bargauge",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.001
              },
              {
                "color": "red",
                "value": 0.01
              }
            ]
          }
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_analysis_hate_speech_score_bucket[10m])",
          "legendFormat": "le={{le}}"
        }
      ]
    },
    {
      "id": 20,
      "title": "Application Logs - All Services",
      "description": "Structured logs from API and Worker. Filter by service={api,worker} or level={info,error,warning}.",
      "type": "logs",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": false,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "{job=\"repops\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 21,
      "title": "Error Log Rate",
      "description": "Count of error-level log lines per minute.",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "sum by (service) (rate({job=\"repops\", level=\"error\"}[1m]))",
          "legendFormat": "{{service}} errors"
        }
      ]
    },
    {
      "id": 22,
      "title": "Collection Errors (Prometheus)",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 34
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(repops_collection_errors_total[5m])",
          "legendFormat": "{{error_type}}"
        }
      ]
    }
  ]
}