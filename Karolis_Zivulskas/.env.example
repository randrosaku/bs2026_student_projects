# ============================================================
# RepOps — Environment Configuration
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# App
ENVIRONMENT=development
LOG_LEVEL=INFO

# Database (PostgreSQL)
DATABASE_URL=postgresql+psycopg://repops:repops@localhost:5432/repops

# Redis (Celery broker + backend)
REDIS_URL=redis://localhost:6379/0

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=repops

# ============================================================
# AWS
# ============================================================
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_EVIDENCE_BUCKET=repops-evidence

# ============================================================
# Facebook / Meta
# ============================================================
# JSON-encoded Playwright session cookies exported from a logged-in browser.
# Format: '[{"name":"c_user","value":"...","domain":".facebook.com",...}]'
FB_SESSION_COOKIES=

# ============================================================
# Analysis
# ============================================================
# Supported languages — posts in other languages are stored but not ML-analysed.
# Currently supported: en (English) and lt (Lithuanian).
SUPPORTED_LANGUAGES=["en","lt"]

# Hate speech classifier (English). Lithuanian posts are translated before classification.
HATE_SPEECH_MODEL=facebook/roberta-hate-speech-dynabench-r4-target
# Translation model used for Lithuanian → English
LT_TO_EN_MODEL=Helsinki-NLP/opus-mt-lt-en

HATE_SPEECH_THRESHOLD=0.6        # score >= this → flagged for review
AUTO_REPORT_THRESHOLD=0.9        # score >= this → auto-reported
CLAIMBUSTER_API_KEY=             # https://idir.uta.edu/claimbuster/

# Comma-separated proxy URLs: http://user:pass@host:port
PROXY_LIST=

# ============================================================
# Alerting
# ============================================================
SLACK_WEBHOOK_URL=
ALERT_EMAIL=
SMTP_HOST=localhost
SMTP_PORT=587

# ============================================================
# Monitoring
# ============================================================
PROMETHEUS_PORT=9091
